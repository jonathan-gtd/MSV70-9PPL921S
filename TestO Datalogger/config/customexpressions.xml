<customexpressions>
	<customexpression>
		<ecu>MSV70</ecu>
		<job>E85</job>
		<result>
			<resultname>STAT_STFT_BANK1_PCT</resultname>
			<expression>(STAT_INTEGRATOR_BANK1_WERT-1)*100</expression>
		</result>
		<result>
			<resultname>STAT_STFT_BANK2_PCT</resultname>
			<expression>(STAT_INTEGRATOR_BANK2_WERT-1)*100</expression>
		</result>
		<result>
			<resultname>STAT_LTFT_MUL_BANK1_PCT</resultname>
			<expression>(STAT_ADAPTION_MULTIPLIKATIV_BANK1_WERT-1)*100</expression>
		</result>
		<result>
			<resultname>STAT_LTFT_MUL_BANK2_PCT</resultname>
			<expression>(STAT_ADAPTION_MULTIPLIKATIV_BANK2_WERT-1)*100</expression>
		</result>
		<result>
			<resultname>STAT_TOTAL_CORR_BANK1_PCT</resultname>
			<expression>(STAT_INTEGRATOR_BANK1_WERT*STAT_ADAPTION_MULTIPLIKATIV_BANK1_WERT-1)*100</expression>
		</result>
		<result>
			<resultname>STAT_TOTAL_CORR_BANK2_PCT</resultname>
			<expression>(STAT_INTEGRATOR_BANK2_WERT*STAT_ADAPTION_MULTIPLIKATIV_BANK2_WERT-1)*100</expression>
		</result>
		<result>
			<resultname>STAT_LAMBDA_AVG</resultname>
			<expression>(STAT_LAMBDA_BANK1_WERT+STAT_LAMBDA_BANK2_WERT)/2</expression>
		</result>
	</customexpression>
	<customexpression>
		<ecu>MSV70</ecu>
		<job>E85_INJ</job>
		<result>
			<resultname>STAT_INJ_AVG_MS</resultname>
			<expression>(STAT_EINSPRITZZEIT_ZYL1_WERT+STAT_EINSPRITZZEIT_ZYL2_WERT+STAT_EINSPRITZZEIT_ZYL3_WERT+STAT_EINSPRITZZEIT_ZYL4_WERT+STAT_EINSPRITZZEIT_ZYL5_WERT+STAT_EINSPRITZZEIT_ZYL6_WERT)/6</expression>
		</result>
	</customexpression>
</customexpressions>
